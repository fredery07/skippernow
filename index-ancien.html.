<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="SkipperNow — trouvez et réservez un skipper professionnel.">
  <title>SkipperNow</title>
  <link rel="stylesheet" href="styles.css">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
  <header class="topbar">
    <a class="brand" href="#home"><span>⚓</span>SkipperNow</a>
    <nav>
      <button class="ghost" data-open="auth">Se connecter</button>
      <button class="primary" data-open="skipper">Devenir skipper</button>
    </nav>
  </header>

  <main id="home">
    <section class="hero">
      <div>
        <p class="eyebrow">Côte d’Azur</p>
        <h1>Votre skipper, au bon port, au bon moment.</h1>
        <p>Réservez un professionnel vérifié pour une demi-journée, une journée ou plusieurs jours.</p>
      </div>
    </section>

    <section class="search-panel">
      <select id="port">
        <option value="">Tous les ports</option>
        <option>Cannes</option><option>Antibes</option><option>Golfe-Juan</option><option>Nice</option><option>Monaco</option>
      </select>
      <input type="date" id="date">
      <select id="duration">
        <option>Demi-journée</option><option>Journée</option><option>Plusieurs jours</option>
      </select>
      <button class="primary" id="searchBtn">Trouver un skipper</button>
    </section>

    <section class="section">
      <div class="section-head">
        <div><p class="eyebrow">Professionnels vérifiés</p><h2>Skippers disponibles</h2></div>
        <span id="count">3 profils</span>
      </div>
      <div class="grid" id="skipperGrid"></div>
    </section>

    <section class="steps section">
      <article><b>1</b><h3>Décrivez la mission</h3><p>Port, date, durée et bateau.</p></article>
      <article><b>2</b><h3>Choisissez le skipper</h3><p>Consultez son profil, ses tarifs et ses avis.</p></article>
      <article><b>3</b><h3>Réservez</h3><p>La demande est enregistrée dans votre espace.</p></article>
    </section>
  </main>

  <section id="dashboard" class="dashboard hidden">
    <aside>
      <a class="brand" href="#home"><span>⚓</span>SkipperNow</a>
      <button data-tab="overview" class="active">Vue d’ensemble</button>
      <button data-tab="bookings">Réservations</button>
      <button data-tab="profile">Mon profil</button>
      <button id="logoutBtn">Se déconnecter</button>
    </aside>
    <div class="dashboard-content">
      <div class="dash-head"><div><p class="eyebrow" id="roleLabel">ESPACE CLIENT</p><h2 id="welcome">Bienvenue</h2></div></div>
      <div id="dashBody"></div>
    </div>
  </section>

  <dialog id="authDialog">
    <button class="close" data-close>×</button>
    <h2>Bienvenue sur SkipperNow</h2>
    <div class="tabs"><button id="loginTab" class="active">Connexion</button><button id="signupTab">Créer un compte</button></div>
    <form id="authForm">
      <input id="name" placeholder="Prénom et nom" class="signup-only hidden">
      <select id="role" class="signup-only hidden"><option value="client">Je suis client</option><option value="skipper">Je suis skipper</option></select>
      <input id="email" type="email" placeholder="Email" required>
      <input id="password" type="password" placeholder="Mot de passe" minlength="6" required>
      <button class="primary wide" type="submit">Continuer</button>
      <button class="link-btn" type="button" id="forgotBtn">Mot de passe oublié</button>
      <p class="form-message" id="authMessage"></p>
    </form>
  </dialog>

  <dialog id="profileDialog">
    <button class="close" data-close>×</button>
    <div id="profileContent"></div>
  </dialog>

  <dialog id="bookingDialog">
    <button class="close" data-close>×</button>
    <h2>Demande de réservation</h2>
    <form id="bookingForm">
      <input type="hidden" id="bookingSkipper">
      <input id="boat" placeholder="Type de bateau" required>
      <input id="phone" placeholder="Téléphone" required>
      <textarea id="message" placeholder="Précisions sur la mission"></textarea>
      <button class="primary wide">Envoyer la demande</button>
      <p class="form-message" id="bookingMessage"></p>
    </form>
  </dialog>

  <script src="config.js"></script>
  <script src="app.js"></script>
</body>
</html>
